# ─────────────────────────────────────────────────────────────────────────────
# Echo — example environment file
#
# Copy this to your real env file and fill in the blanks. Locally the code loads
# variables from `.venv/.env` (see load_dotenv(".venv/.env") in the source), so:
#
#     cp .example.env .venv/.env      # then edit .venv/.env
#
# In hosted environments (e.g. Render) set these as platform env vars instead.
# Credential JSON files are NOT env vars — place them under SECRETS_DIR (.secrets/).
# ─────────────────────────────────────────────────────────────────────────────


# == REQUIRED ==================================================================
# The app will not start / function correctly without these.

# OpenAI — powers the LangGraph ReAct agent (read automatically by langchain-openai).
OPENAI_API_KEY=

# Tavily — web search tool available to the agent (read automatically by langchain_tavily).
TAVILY_API_KEY=

# Green API partner token — outbound "send as the user" + instance pool.
# Required: code raises ValueError if missing.
GREEN_API_PARTNER_TOKEN=

# Inbound 360dialog webhook bearer secret — required: webhook raises ValueError if missing.
# Incoming requests must send  Authorization: Bearer <WEBHOOK_SECRET>
WEBHOOK_SECRET=

# 360dialog / WhatsApp Cloud API — used by the Cloud API adapter to send messages/templates.
D360_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=


# == SECRETS / CREDENTIAL FILES ===============================================
# These point at JSON credential files living under SECRETS_DIR (default ".secrets").
# Put the actual JSON files there; only the directory/filename are configured here.

# Directory that holds credential JSONs (Firebase, Google STT, etc.).
SECRETS_DIR=.secrets

# Filename (inside SECRETS_DIR) of the Google Cloud Speech-to-Text service account.
GOOGLE_SPEECH_CREDENTIALS=your-google-speech-service-account.json
# NOTE: Firebase service account is loaded from SECRETS_DIR as well (db/base.py).


# == OPTIONAL (have sane defaults) ============================================

# Public base URL of the app (used in login links and Google OAuth redirects).
APP_BASE_URL=https://inme-1.onrender.com

# Web server port.
PORT=8000

# Green API partner base URL.
GREEN_API_PARTNER_API_URL=https://api.green-api.com

# x-Hub-Signature app secret for Cloud API signature verification.
WHATSAPP_APP_SECRET=your_app_secret

# whatsapp-web.js / node service base URL (still referenced for instance deployment URLs).
NODE_URL=http://localhost:3000

# Background worker tuning.
CONTACTS_REFRESH_SEC=3600     # contact re-sync interval (seconds)
POOL_SIZE=1                   # warm Green API instances to keep ready


# == COST / METRICS LABELS (estimates only) ===================================
LLM_MODEL_NAME=gpt-4_1            # label used in metrics
LLM_PRICE_PER_M_TOKEN=6.00       # USD per 1M tokens, for cost estimation
STT_PRICE_PER_MIN_USD=0.024      # USD per STT minute, for cost estimation


# == ANALYTICS (Google Analytics 4 Measurement Protocol) ======================
# Code ships with working defaults; override to point at your own GA4 property.
GA4_MEASUREMENT_ID=
GA4_API_SECRET=
GA4_COLLECT_URL=https://www.google-analytics.com/mp/collect
GA4_DEBUG=0                       # set to "1" in staging to mark events debug_mode=1
GA4_CLIENT_SALT=echo_salt         # used to derive a client_id when none is provided


# == LANGSMITH TRACING (opt-in) ===============================================
# Set LANGCHAIN_TRACING_V2=true AND LANGCHAIN_API_KEY to enable tracing.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=default


# == TESTS (integration only) =================================================
# Real user id used by the opt-in integration tests under tests/test_int_*.py.
INTEGRATION_TEST_USER_ID=
